{
  "functions": {
    "api/**/*.py": {
      "memory": 1024,
      "maxDuration": 30,
      "excludeFiles": "{.git/**,.vscode/**,dist/**,node_modules/**,public/**,src/**,supabase/**}"
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/index.py" },
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
